-- ============================================================
-- PROJECT 2 — Coffee Shop Sales & Performance
-- SQL Script — Analytical Base with Shift, MoM and Store Ranking
-- ============================================================
-- INSTRUCTIONS:
-- 1. Import Coffee_Shop_Sales.xlsx in DB Browser as table
--    "Coffee Shop Sales"
-- 2. Run each CTE individually to validate before chaining
-- 3. Expected validation at the end:
--    - Total rows: 149,116
--    - Lower Manhattan / Morning: pct_store ~ 62.6
--    - Astoria / Evening: pct_store ~ 21.0
--    - Sustainably Grown Organic Lg: ranking = 1 in at least one store
--    - January: previous_revenue NULL for all stores
--    - March: mon_variation_pct ~ +29.8
-- ============================================================


-- ── CTE 1: CLEAN BASE ────────────────────────────────────────
-- Goal: rename columns, fix date format, cast unit_price to
-- REAL and create three derived columns:
--   · date  → YYYY-MM-DD (rebuilt from MM/DD/YYYY source)
--   · month → YYYY-MM    (for MoM grouping and Power BI time axis)
--   · hour  → integer    (for intraday line chart in Power BI)
--   · shift → Morning / Afternoon / Night (core analytical dimension)
--
-- Why REPLACE on unit_price:
--   Source file uses Brazilian locale — decimal separator is comma.
--   SQLite reads "3,75" as text and truncates to 3 on multiplication.
--   REPLACE swaps comma for dot before CAST to REAL fixes this.
--
-- Why substr for date:
--   Source format is MM/DD/YYYY. DATE() and strftime() only work
--   natively with YYYY-MM-DD. substr rebuilds the string in the
--   correct order without any external function.
WITH base AS (
  SELECT
    transaction_id                                        AS id,
    substr(transaction_date, 7, 4) || '-' ||
    substr(transaction_date, 1, 2) || '-' ||
    substr(transaction_date, 4, 2)                        AS date,
    substr(transaction_date, 7, 4) || '-' ||
    substr(transaction_date, 1, 2)                        AS month,
    transaction_qty                                       AS qty,
    store_location                                        AS store,
    CAST(REPLACE(unit_price, ',', '.') AS REAL)           AS unit_price,
    product_category                                      AS category,
    product_type                                          AS product,
    product_detail,
    transaction_qty *
      CAST(REPLACE(unit_price, ',', '.') AS REAL)         AS revenue,
    CAST(SUBSTR(transaction_time, 1, 2) AS INT)           AS hour,
    CASE
      WHEN CAST(SUBSTR(transaction_time, 1, 2) AS INT) < 12 THEN 'Morning'
      WHEN CAST(SUBSTR(transaction_time, 1, 2) AS INT) < 17 THEN 'Afternoon'
      ELSE 'Night'
    END                                                   AS shift
  FROM "Coffee Shop Sales"
),


-- ── CTE 2: KPIs BY PRODUCT ───────────────────────────────────
-- Goal: aggregate revenue, quantity, average price and
-- transaction count at the product_detail level.
-- Granularity: 1 row per category + product + product_detail.
-- Base for: scatter chart (avg_price × qty_total) and
-- The Aces ranking in Power BI.
kpis_product AS (
  SELECT
    category,
    product,
    product_detail,
    SUM(revenue)                AS revenue_product,
    SUM(qty)                    AS qty_total,
    ROUND(AVG(unit_price), 2)   AS average_price,
    COUNT(id)                   AS transactions
  FROM base
  GROUP BY category, product, product_detail
),


-- ── CTE 3: KPIs BY SHIFT AND STORE ───────────────────────────
-- Goal: aggregate revenue and transactions at the
-- store + shift level — the core of the specialization analysis.
-- Granularity: 1 row per store + shift (9 rows total: 3 × 3).
--
-- How pct_store works:
--   SUM(SUM(revenue)) OVER (PARTITION BY store)
--   → outer SUM aggregates within the GROUP BY result,
--     OVER (PARTITION BY store) creates a window that sums
--     all shifts for the same store.
--   This gives the % of each shift within its own store total —
--   e.g. Lower Manhattan Morning = 62.6% of LM total revenue.
kpis_shift_store AS (
  SELECT
    store,
    shift,
    SUM(revenue)                                            AS revenue_shift,
    COUNT(id)                                               AS transactions_shift,
    ROUND(SUM(revenue) * 100.0 /
      SUM(SUM(revenue)) OVER (PARTITION BY store), 2)       AS pct_store
  FROM base
  GROUP BY store, shift
),


-- ── CTE 4: PRODUCT RANKING BY STORE ──────────────────────────
-- Goal: rank each product by revenue within each store.
--
-- How RANK() works here:
--   RANK() OVER (PARTITION BY store ORDER BY SUM(revenue) DESC)
--   → "within each store (PARTITION BY), assign position from
--      highest to lowest revenue (ORDER BY DESC)"
--
-- PARTITION BY store → ranking resets for each store.
--   Without it, there would be a single global ranking across
--   all products from all stores — not what we want.
ranking_product AS (
  SELECT
    store,
    product_detail,
    SUM(revenue)                                            AS revenue_product_store,
    RANK() OVER (
      PARTITION BY store
      ORDER BY SUM(revenue) DESC
    )                                                       AS ranking
  FROM base
  GROUP BY store, product_detail
),


-- ── CTE 5: MOM VARIATION BY STORE ────────────────────────────
-- Goal: for each store and month, retrieve the previous month
-- revenue and calculate the percentage variation.
--
-- How LAG works here:
--   LAG(SUM(revenue)) OVER (PARTITION BY store ORDER BY month)
--   → "within the same store (PARTITION BY),
--      get the revenue from the previous row ordered by month"
--
-- PARTITION BY store → resets LAG for each store.
--   Without it, Jan/Astoria LAG would pick the last month of
--   another store — wrong.
--
-- ORDER BY month → defines that "previous" = chronologically
--   earlier month.
--
-- First row of each store → returns NULL in LAG.
--   Correct: there is no previous month to compare against.
mon AS (
  SELECT
    store,
    month,
    SUM(revenue)                                            AS month_revenue,
    LAG(SUM(revenue))
      OVER (PARTITION BY store ORDER BY month)              AS previous_revenue,
    ROUND(
      (SUM(revenue) - LAG(SUM(revenue))
        OVER (PARTITION BY store ORDER BY month))
      * 100.0
      / LAG(SUM(revenue))
        OVER (PARTITION BY store ORDER BY month),
    2)                                                      AS mon_variation_pct
  FROM base
  GROUP BY store, month
)


-- ── FINAL QUERY: JOIN ALL LAYERS AT TRANSACTION GRANULARITY ──
-- LEFT JOIN ensures all 149,116 base rows are returned.
-- Rows without a previous month (January of each store)
-- will have NULL in previous_revenue and mon_variation_pct — correct.
-- Column order follows analytical logic:
--   identifiers → time → location → product → metrics → aggregates
SELECT
  b.id,
  b.date,
  b.month,
  b.hour,
  b.shift,
  b.store,
  b.category,
  b.product,
  b.product_detail,
  b.qty,
  b.unit_price,
  b.revenue,
  t.revenue_shift,
  t.transactions_shift,
  t.pct_store,
  k.revenue_product,
  k.qty_total,
  k.average_price,
  r.revenue_product_store,
  r.ranking                   AS ranking_product_in_store,
  m.month_revenue,
  m.previous_revenue,
  m.mon_variation_pct
FROM base b
LEFT JOIN kpis_shift_store t
  ON b.store  = t.store
 AND b.shift  = t.shift
LEFT JOIN kpis_product k
  ON b.product_detail = k.product_detail
LEFT JOIN ranking_product r
  ON b.store        = r.store
 AND b.product_detail = r.product_detail
LEFT JOIN mon m
  ON b.store  = m.store
 AND b.month  = m.month
ORDER BY b.date, b.store;
